{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://veil.local/schemas/evidence-report-v1.json",
  "title": "Veil Evidence Report v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "runId",
    "generatedAtUtc",
    "summary",
    "findings"
  ],
  "properties": {
    "schemaVersion": {
      "const": "veil-evidence-report-v1"
    },
    "runId": {
      "type": "string"
    },
    "generatedAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "$ref": "#/$defs/EvidenceSummary"
    },
    "findings": {
      "type": "array",
      "description": "Raw-free all findings, including baselineStatus=new and baselineStatus=suppressed when baseline is used.",
      "items": {
        "$ref": "#/$defs/SafeFindingApiV1"
      }
    }
  },
  "$defs": {
    "SeverityCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "Low",
        "Medium",
        "High",
        "Critical"
      ],
      "properties": {
        "Low": {
          "type": "integer",
          "minimum": 0
        },
        "Medium": {
          "type": "integer",
          "minimum": 0
        },
        "High": {
          "type": "integer",
          "minimum": 0
        },
        "Critical": {
          "type": "integer",
          "minimum": 0
        }
      },
      "description": "Zero-filled severity counts. All four keys are required even when values are 0."
    },
    "EvidenceSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "totalFindings",
        "suppressedFindings",
        "effectiveFindings",
        "severityCounts",
        "allSeverityCounts",
        "suppressedSeverityCounts",
        "coverageComplete"
      ],
      "properties": {
        "totalFindings": {
          "type": "integer",
          "minimum": 0
        },
        "suppressedFindings": {
          "type": "integer",
          "minimum": 0
        },
        "effectiveFindings": {
          "type": "integer",
          "minimum": 0
        },
        "severityCounts": {
          "$ref": "#/$defs/SeverityCounts"
        },
        "allSeverityCounts": {
          "$ref": "#/$defs/SeverityCounts"
        },
        "suppressedSeverityCounts": {
          "$ref": "#/$defs/SeverityCounts"
        },
        "coverageComplete": {
          "type": "boolean",
          "description": "False when scan stopped because of max_findings/max_file_count/text oversize/read coverage gap. Counts are observed values only."
        }
      }
    },
    "SafeFindingApiV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "findingId",
        "baselineFingerprint",
        "path",
        "lineNumber",
        "ruleId",
        "severity",
        "score",
        "grade",
        "maskedSnippet",
        "category",
        "tags",
        "baselineStatus"
      ],
      "properties": {
        "findingId": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "lineNumber": {
          "type": "integer",
          "minimum": 1
        },
        "ruleId": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": [
            "Low",
            "Medium",
            "High",
            "Critical"
          ]
        },
        "score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "grade": {
          "type": "string",
          "enum": [
            "Low",
            "Medium",
            "High",
            "Critical"
          ]
        },
        "maskedSnippet": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "baselineStatus": {
          "type": "string",
          "enum": [
            "new",
            "suppressed",
            "none"
          ]
        },
        "baselineFingerprint": {
          "type": "string",
          "description": "Opaque baseline suppression key. Distinct from findingId; used for baseline matching."
        }
      }
    }
  }
}
